{
  "name": "eslint-plugin-java-lang",
  "version": "0.4.1",
  "description": "ESLint plugin and utilities for Java",
  "homepage": "https://github.com/mshima/eslint-plugin-java-lang",
  "bugs": "https://github.com/mshima/eslint-plugin-java-lang/issues",
  "repository": {
    "type": "git",
    "url": "git://github.com/mshima/eslint-plugin-java-lang.git"
  },
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/marcelo-boveto-shima"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "wasm"
  ],
  "scripts": {
    "build": "tsc && npm run copy:wasm",
    "copy:wasm": "cpy node_modules/tree-sitter-java-orchard/tree-sitter-java_orchard.wasm wasm/ --flat",
    "format": "prettier --write package.json vitest.config.ts .prettierrc.json eslint.config.ts tsconfig.json src/",
    "lint": "eslint . --fix",
    "prepare": "npm run build",
    "pretest": "eslint && prettier . --check",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "web-tree-sitter": "^0.26.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "cpy-cli": "^7.0.0",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "prettier-plugin-packagejson": "^3.0.2",
    "tree-sitter-java-orchard": "0.5.6",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "eslint": ">=9"
  },
  "peerDependenciesMeta": {
    "eslint": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22"
  }
}
