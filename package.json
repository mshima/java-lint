{
  "name": "eslint-plugin-java",
  "version": "0.3.0",
  "description": "ESLint plugin and utilities for Java",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin/index.d.ts",
      "default": "./dist/plugin/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "homepage": "https://github.com/mshima/eslint-plugin-java",
  "bugs": "https://github.com/mshima/eslint-plugin-java/issues",
  "type": "module",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git://github.com/mshima/eslint-plugin-java.git"
  },
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/marcelo-boveto-shima"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "test": "vitest run --coverage",
    "lint": "eslint . --fix",
    "format": "prettier --write package.json vitest.config.ts .prettierrc.json eslint.config.js tsconfig.json src/"
  },
  "dependencies": {
    "tree-sitter-java-orchard": "^0.5.5",
    "web-tree-sitter": "^0.26.7"
  },
  "peerDependencies": {
    "eslint": ">=9"
  },
  "peerDependenciesMeta": {
    "eslint": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^24.0.13",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.30.1",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "prettier-plugin-packagejson": "^2.5.18",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.36.0",
    "vitest": "^3.2.4"
  }
}
